@startuml Shared_ClassDiagram
skinparam classAttributeIconSize 0
skinparam linetype ortho

package "dto" {
  class LoginDTO {
    - email: String
    - password: String
    + getEmail(): String
    + getPassword(): String
  }

  class RegistrazioneDTO {
    - nome: String
    - cognome: String
    - email: String
    - password: String
    - citta: String
    - nazione: String
    - ristoratore: boolean
    + getNome(): String
    + getCognome(): String
    + getEmail(): String
    + getPassword(): String
    + getCitta(): String
    + getNazione(): String
    + isRistoratore(): boolean
  }

  class RistoranteDTO {
    - idRistorante: Integer
    - nomeRistorante: String
    - email: String
    - citta: String
    - nazione: String
    - via: String
    - numeroCivico: int
    - fasciaPrezzo: int
    - delivery: boolean
    - prenotazioneOnline: boolean
    - tipoCucina: int
    + RistoranteDTO(nomeRistorante, email, citta, nazione, via, numeroCivico, fasciaPrezzo, delivery, prenotazioneOnline, tipoCucina)
    + RistoranteDTO(idRistorante, nomeRistorante, email, citta, nazione, via, numeroCivico, fasciaPrezzo, delivery, prenotazioneOnline, tipoCucina)
    + getIdRistorante(): Integer
    + getNomeRistorante(): String
    + getEmail(): String
    + getCitta(): String
    + getNazione(): String
    + getVia(): String
    + getNumeroCivico(): int
    + getFasciaPrezzo(): int
    + isDelivery(): boolean
    + isPrenotazioneOnline(): boolean
    + getTipoCucina(): int
  }

  class RecensioneDTO {
    - email: String
    - idRistorante: int
    - valutazione: int
    - recensione: String
    - risposta: String
    + getEmail(): String
    + getIdRistorante(): int
    + getValutazione(): int
    + getRecensione(): String
    + getRisposta(): String
    + setValutazione(valutazione: int): void
  }

  class PreferitiDTO {
    - email: String
    - idRistorante: int
    + getEmail(): String
    + getIdRistorante(): int
  }

  class RiepilogoRecensioniDTO {
    - numeroRecensioni: int
    - mediaValutazioni: double
    + getNumeroRecensioni(): int
    + getMediaValutazioni(): double
  }

  class TipoCucinaDTO {
    - idTipoCucina: int
    - tipoCucina: String
    + getIdTipoCucina(): int
    + getTipoCucina(): String
    + getId(): int
  }

  class FiltroRicercaDTO {
    - nomeRistorante: String
    - citta: String
    - nazione: String
    - fasciaPrezzoMassima: Integer
    - delivery: Integer
    - prenotazioneOnline: Integer
    - tipoCucina: Integer
    + getNomeRistorante(): String
    + getCitta(): String
    + getNazione(): String
    + getFasciaPrezzoMassima(): Integer
    + getDelivery(): Integer
    + getPrenotazioneOnline(): Integer
    + getTipoCucina(): Integer
  }
}

package "domain" {
  class Utente <<entity>> {
    - email: String
    - nomeUtente: String
    - cognomeUtente: String
    - hashpwd: String
    - nazione: String
    - citta: String
    - ristoratore: boolean
    + getNomeUtente(): String
    + getCognomeUtente(): String
    + getEmail(): String
    + getNazione(): String
    + getCitta(): String
    + getRistoratore(): boolean
    + getHashpwd(): String
    + setNomeUtente(nomeUtente: String): void
    + setCognome(cognomeUtente: String): void
    + setNazione(nazione: String): void
    + setCitta(citta: String): void
  }

  class Ristorante <<entity>> {
    - idRistorante: int
    - nomeRistorante: String
    - email: String
    - nazione: String
    - citta: String
    - via: String
    - numeroCivico: int
    - fasciaPrezzo: int
    - delivery: boolean
    - prenotazioneOnline: boolean
    - idTipoCucina: int
    + getIdRistorante(): int
    + getNomeRistorante(): String
    + getEmail(): String
    + getNazione(): String
    + getCitta(): String
    + getVia(): String
    + getNumeroCivico(): int
    + getFasciaPrezzo(): int
    + getDelivery(): boolean
    + getPrenotazioneOnline(): boolean
    + getIdTipoCucina(): int
  }

  class Recensione <<entity>> {
    - email: String
    - idRistorante: int
    - valutazione: int
    - recensione: String
    - risposta: String
    + getEmail(): String
    + getIdRistorante(): int
    + getValutazione(): int
    + getRecensione(): String
    + getRisposta(): String
    + setValutazione(valutazione: int): void
  }

  class Preferito <<entity>> {
    - email: String
    - idRistorante: int
    + getEmail(): String
    + getIdRistorante(): int
  }
}

package "enums" {
  enum RuoloUtente {
    CLIENTE
    RISTORATORE
  }
  enum CampoRecensione {
    RECENSIONE
    VALUTAZIONE
    RISPOSTA
  }
  enum CampoRistorante {
    NOME
    CITTA
    NAZIONE
    VIA
    FASCIA_PREZZO
  }
  enum CampoUtente {
    NOMEUTENTE
    COGNOMEUTENTE
    CITTA
    NAZIONE
    PASSWORD
    RISTORATORE
  }
}

package "communication" {
  class Richiesta {
    + tipoRichiesta: TipoRichieste
    + contenuto: Object
    + getTipoRichiesta(): TipoRichieste
    + getContenuto(): Object
  }

  class Risposta {
    - successo: boolean
    - contenuto: Object
    - msg: String
    + getContenuto(): Object
    + getMsg(): String
    + getSuccesso(): boolean
  }

  enum TipoRichieste {
    LOGIN
    REGISTER
    LOGOUT
    GET_UTENTE
    GET_RISTORANTE
    CREA_RISTORANTE
    AGGIORNA_RISTORANTE
    ELIMINA_RISTORANTE
    CERCA_RISTORANTE
    ESISTE_RISTORANTE
    GET_RECENSIONI_RISTORANTE
    GET_RECENSIONI_UTENTE
    GET_RECENSIONI_BYEMAIL
    SCRIVI_RECENSIONE
    MODIFICA_RECENSIONE
    ELIMINA_RECENSIONE
    RISPONDI_RECENSIONE
    MODIFICA_RISPOSTA
    RIEPILOGO_RECENSIONE
    GET_PREFERITI
    AGGIUNGI_PREFERITO
    RIMUOVI_PREFERITO
    ESISTE_PREFERITO
    TOGGLE_PREFERITO
    GET_TIPO_CUCINA
    SHUTDOWN_SERVER
  }
}

Richiesta "1" --> "1" TipoRichieste : tipoRichiesta

@enduml